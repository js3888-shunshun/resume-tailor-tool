# Copy to `.env` and fill in. `.env` is gitignored.

# Required from M2 onward (JD analysis / rewrite / cover letter).
ANTHROPIC_API_KEY=sk-ant-...

# Shared login for the deployed/public site. When APP_PASSWORD is unset, the app
# is OPEN (fine for local dev). Set both to gate the deployed site to a few people.
APP_USERNAME=
APP_PASSWORD=

# Optional overrides.
RESUME_TAILOR_MODEL=claude-opus-4-8
# Point at a Linux tectonic binary on a server (the Docker image sets this).
# RESUME_TAILOR_TECTONIC=/usr/local/bin/tectonic
# RESUME_TAILOR_MATERIALS=backend/data/materials.json
# RESUME_TAILOR_OUTPUT_DIR=backend/output
